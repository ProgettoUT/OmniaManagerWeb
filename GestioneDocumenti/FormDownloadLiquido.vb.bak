    Private Sub frmUpload_Load(sender As System.Object, e As System.EventArgs) Handles Me.Load

        Me.Text = "Documenti sinistro"
        Me.Icon = Risorse.Immagini.Icon("view")

        lbNumeroSinistro.BackColor = Color.NavajoWhite

        With ListViewProprieta
            .BackColor = Color.DodgerBlue
            .ForeColor = Color.White
            .View = View.Details
            .LabelEdit = False
            .FullRowSelect = True
            .GridLines = False
            .Sorting = SortOrder.None
            .HeaderStyle = ColumnHeaderStyle.None
            .Scrollable = False

            .Columns.Clear()
            .Columns.Add("Proprieta", 10, HorizontalAlignment.Left)
            .Columns.Add("Valore", 10, HorizontalAlignment.Left)

            .Items.Add(New ListViewItem("Pervenuto"))
            .Items.Add(New ListViewItem("Formato"))
            .Items.Add(New ListViewItem("Cartella"))
            .Items.Add(New ListViewItem("Mittente"))
            .Items.Add(New ListViewItem("Nome"))
            .Items.Add(New ListViewItem("Descrizione"))
            .Items.Add(New ListViewItem("Tipo"))

            .Columns.Item(0).AutoResize(ColumnHeaderAutoResizeStyle.ColumnContent)
            .Columns.Item(1).Width = 10000
        End With

        With btnVisualizza
            .Padding = New Padding(10)
            .Image = Risorse.Immagini.Bitmap("view")
            .ImageAlign = ContentAlignment.MiddleRight
            .Text = "Vedi documento"
            .TextAlign = ContentAlignment.MiddleLeft
        End With
        With btnSalvaFile
            .Padding = New Padding(10)
            .Image = Risorse.Immagini.Bitmap("disk")
            .ImageAlign = ContentAlignment.MiddleRight
            .Text = "Copia documento sul disco M:"
            .TextAlign = ContentAlignment.MiddleLeft
        End With
        With btnEsci
            .Padding = New Padding(10)
            .Image = Risorse.Immagini.Bitmap("esci")
            .ImageAlign = ContentAlignment.MiddleRight
            .Text = "Esci"
            .TextAlign = ContentAlignment.MiddleLeft
        End With

        lbStato.Text = ""

        'normalizzo formato sinistro con - come separatori
        mIdSinistro = mIdSinistro.Replace(".", "-")
    End Sub

    Private Sub frmUpload_Shown(sender As Object, e As System.EventArgs) Handles Me.Shown

        SinistroCorrente = New Sinistri(mIdSinistro)

        lbNumeroSinistro.Text = "Sinistro " + SinistroCorrente.IdSinistroNormalizzato

        With pbInvio
            .Style = ProgressBarStyle.Marquee
            .Enabled = True
        End With

        With ListBoxDocumenti
            .Items.Clear()
            .Refresh()
            .Enabled = False
        End With

        FlagWip = True

        lbStato.Text = "Lettura lista documenti su Liquido..."

        'blocca controlli
        btnVisualizza.Enabled = False
        btnSalvaFile.Enabled = False

        Dim Arg As New SertelEventArgs With {.Operazione = Globale.TipoOperazioneLiquido.LISTALIQUIDO}

        BackgroundWorker1.RunWorkerAsync(Arg)

        Me.Refresh()
    End Sub

    Private Sub frmUpload_FormClosing(sender As Object, e As System.Windows.Forms.FormClosingEventArgs) Handles Me.FormClosing

        On Error Resume Next

        If FlagWip = False Then
            Do While BackgroundWorker1.IsBusy : Application.DoEvents() : Loop
        Else
            e.Cancel = True
        End If
    End Sub

    Private Function ListaDocumentiSinistro() As EsitoBackgroundWorker
        Dim Esito As New EsitoBackgroundWorker
        Try
            Using s As New Utx.ImportaSinistriOMW.Direzione
                s.Proxy = Utx.Globale.UniProxy.Proxy
                s.Timeout = 20000
                Esito.EsitoChiamata = s.ListaDocumentiSinistro(SinistroCorrente.IdSinistroNormalizzato,
                                                               Utx.Globale.UtenteCorrente.UniageUser,
                                                               Utx.Globale.UtenteCorrente.UniagePw,
                                                               Utx.Globale.Token)
                If Esito.EsitoChiamata.Esito = True Then
                    Esito.TipoRisposta = "OK"
                    Esito.Risposta = ""
                Else
                    Esito.TipoRisposta = "KO"
                    Esito.ExMessage = Esito.EsitoChiamata.Errore
                End If
            End Using
        Catch ex As Net.WebException
            Esito.TipoRisposta = "KO"
            Esito.Risposta = ex.Message
            Esito.ExMessage = ex.Message
        Catch ex As UnauthorizedAccessException
            Esito.TipoRisposta = "KO"
            Esito.Risposta = "Autorizzazione negata: controllare user/password"
            Esito.ExMessage = ex.Message
        Catch ex As Exception
            Esito.TipoRisposta = "KO"
            Esito.Risposta = ex.Message
            Esito.ExMessage = ex.Message
        End Try

        Return Esito
    End Function

    Private Function ScaricaFileLiquido(IdDocumento As String,
                                        FileDest As String) As EsitoBackgroundWorker

        Dim Esito As New EsitoBackgroundWorker

        Try
            Using s As New Utx.ImportaSinistriOMW.Direzione
                s.Proxy = Utx.Globale.UniProxy.Proxy
                Esito.EsitoChiamata = s.ScaricaDocumentoSinistro(IdDocumento,
                                           Utx.Globale.UtenteCorrente.UniageUser,
                                           Utx.Globale.UtenteCorrente.UniagePw,
                                           Utx.Globale.Token)

                If Esito.EsitoChiamata.Esito = True Then
                    'salvo il documento
                    File.WriteAllBytes(FileDest, Esito.EsitoChiamata.Documento)
                    Esito.TipoRisposta = "OK"
                Else
                    Esito.Risposta = "KO"
                    Esito.ExMessage = Esito.EsitoChiamata.Errore
                End If
            End Using

        Catch ex As Net.WebException
            Esito.Risposta = ex.Message
            Esito.ExMessage = ex.Message
        Catch ex As UnauthorizedAccessException
            Esito.Risposta = "KO|Autorizzazione negata: controllare user/password"
            Esito.ExMessage = ex.Message
        Catch ex As Exception
            Esito.Risposta = "KO|" + ex.Message
            Esito.ExMessage = ex.Message
        End Try
        Return Esito
    End Function

    Private Sub ListBoxDocumenti_SelectedIndexChanged(sender As System.Object, e As System.EventArgs) Handles ListBoxDocumenti.SelectedIndexChanged

        Try
            If ListBoxDocumenti.SelectedItem Is Nothing Then ListBoxDocumenti.SelectedIndex = 0
            If ListBoxDocumenti.SelectedIndex < 0 Then Exit Sub

            Dim d As Utx.ImportaSinistriOMW.DocumentoInfo = ListBoxDocumenti.SelectedItem
            If d.IdFile.Length > 0 Then

                With ListViewProprieta
                    .Items.Clear()
                    .Items.Add(New ListViewItem("Pervenuto")) : .Items(0).SubItems.Add(d.DataPervenimento)
                    .Items.Add(New ListViewItem("Formato")) : .Items(1).SubItems.Add(d.FileExt.Substring(1).ToUpper)
                    .Items.Add(New ListViewItem("Cartella")) : .Items(2).SubItems.Add(d.IdCartella)
                    .Items.Add(New ListViewItem("Mittente")) : .Items(3).SubItems.Add(d.Mittente)
                    .Items.Add(New ListViewItem("Nome")) : .Items(4).SubItems.Add(d.Nome)
                    .Items.Add(New ListViewItem("Descrizione")) : .Items(5).SubItems.Add(d.Descrizione)
                    .Items.Add(New ListViewItem("Tipo")) : .Items(6).SubItems.Add(d.Tipo)
                End With
            End If

        Catch ex As Exception
            Globale.Log.Errore(ex)
            Globale.Log.Info(ex.Message)
        End Try
    End Sub

    Private Sub BackgroundWorker1_DoWork(sender As System.Object,
                                         e As System.ComponentModel.DoWorkEventArgs) Handles BackgroundWorker1.DoWork

        'attraverso e vengono passati i dati per il BackgroundWorker
        'le funzioni invocate restituiscono una struttura esito contenente una risposta
        'e il tipo di chiamata effettuata
        Try
            Dim Esito As New EsitoBackgroundWorker

            Select Case e.Argument.Operazione

                Case Globale.TipoOperazioneLiquido.VISUALIZZA
                    Esito = ScaricaFileLiquido(e.Argument.DocInfo.DocUID, e.Argument.FullPathFileDest)

                Case Globale.TipoOperazioneLiquido.SALVA
                    Esito = ScaricaFileLiquido(e.Argument.DocInfo.DocUID, e.Argument.FullPathFileDest)

                Case Globale.TipoOperazioneLiquido.LISTALIQUIDO
                    Esito = ListaDocumentiSinistro()
            End Select

            'nella struttura esito riporto anche l'operazione fatta per considerazioni a posteriori
            'sulla risposta
            Esito.ArgChiamata = e.Argument

            'restituisco la struttura esito come risultato dell'elaborazione
            e.Result = Esito
        Catch ex As Exception
            Globale.Log.Errore(ex)
        End Try
    End Sub

    Private Sub BackgroundWorker1_RunWorkerCompleted(sender As Object,
                                                     e As System.ComponentModel.RunWorkerCompletedEventArgs) Handles BackgroundWorker1.RunWorkerCompleted

        'fermo la progress bar al max
        With pbInvio
            .Style = ProgressBarStyle.Blocks
            .Value = pbInvio.Maximum
            .Refresh()
        End With

        'analisi dell'esito dell'operazione. e.result contiene la struttura esito
        Try
            Dim Esito As EsitoBackgroundWorker = e.Result

            'Esito.ElaboraRisposta(Esito)

            Select Case Esito.ArgChiamata.Operazione

                Case Globale.TipoOperazioneLiquido.VISUALIZZA

                    If Esito.TipoRisposta = "OK" Then
                        lbStato.Text = "Documento scaricato correttamente"

                        'visualizza il documento aprendo l'applicazione predefinita
                        Process.Start(Esito.ArgChiamata.FullPathFileDest)
                    Else
                        lbStato.Text = Esito.EsitoChiamata.Errore
                    End If

                Case Globale.TipoOperazioneLiquido.SALVA

                    If Esito.TipoRisposta = "OK" Then
                        lbStato.Text = "Documento salvato"
                    Else
                        lbStato.Text = Esito.EsitoChiamata.Errore
                    End If

                Case Globale.TipoOperazioneLiquido.LISTALIQUIDO

                    ListBoxDocumenti.Items.Clear()
                    ListBoxDocumenti.DisplayMember = "Nome"
                    ListBoxDocumenti.Tag = Globale.TipoOperazioneLiquido.LISTALIQUIDO

                    If Esito.TipoRisposta = "OK" Then
                        If Esito.EsitoChiamata.ListaDocumenti.ErrorDescription IsNot Nothing AndAlso
                            Esito.EsitoChiamata.ListaDocumenti.ErrorDescription.StartsWith("Sinistro non trovato", StringComparison.InvariantCultureIgnoreCase) Then

                            lbStato.Text = "Sinistro non trovato"

                            'blocca controlli
                            btnVisualizza.Enabled = False
                            btnSalvaFile.Enabled = False

                        ElseIf Esito.EsitoChiamata.ListaDocumenti.DocumentoInfoList Is Nothing Then

                            lbStato.Text = "Non esistono documenti visibili all'agenzia"

                            'blocca controlli
                            btnVisualizza.Enabled = False
                            btnSalvaFile.Enabled = False
                        Else
                            For k As Integer = 0 To Esito.EsitoChiamata.ListaDocumenti.DocumentoInfoList.GetUpperBound(0)
                                ListBoxDocumenti.Items.Add(Esito.EsitoChiamata.ListaDocumenti.DocumentoInfoList(k))
                            Next
                            lbStato.Text = String.Format("documenti trovati su Liquido: {0}", Esito.EsitoChiamata.ListaDocumenti.DocumentoInfoList.GetUpperBound(0) + 1)

                            If ListBoxDocumenti.Items.Count > 0 Then ListBoxDocumenti.SelectedIndex = 0
                        End If

                    ElseIf Esito.TipoRisposta = "KO" Then
                        'si è verificato un'errore
                        lbStato.Text = Esito.Risposta
                    End If

                    btnVisualizza.Enabled = (Esito.TipoRisposta = "OK")
                    btnSalvaFile.Enabled = (Esito.TipoRisposta = "OK")
            End Select

        Catch ex As Exception
            Globale.Log.Errore(ex)
        Finally
            ListBoxDocumenti.Enabled = True
            btnEsci.Enabled = True
            FlagWip = False
        End Try
    End Sub

    Private Sub btnEsci_Click(sender As System.Object, e As System.EventArgs) Handles btnEsci.Click
        Me.Close()
    End Sub

    Private Sub btnVisualizza_Click(sender As System.Object, e As System.EventArgs) Handles btnVisualizza.Click
        Try
            If ListBoxDocumenti.SelectedIndex < 0 Then
                MsgBox("Selezionare il documento da visualizzare", MsgBoxStyle.Information, Utx.Globale.TitoloApp)
                Exit Sub
            End If

            Dim Arg As New SertelEventArgs

            If ListBoxDocumenti.Tag = Globale.TipoOperazioneLiquido.LISTALIQUIDO Then

                If ListBoxDocumenti.SelectedItem.IdFile.Length = 0 Then Exit Sub

                Arg.DocInfo = ListBoxDocumenti.SelectedItem
                Arg.FullPathFileDest = FileDestinazione(Utx.Globale.Paths.CartellaDocUtente)
            Else
                Arg.DocInfo = ListBoxDocumenti.SelectedItem
                Arg.FullPathFileDest = FileDestinazione(Utx.Globale.Paths.CartellaDocUtente)
            End If

            With pbInvio
                .Style = ProgressBarStyle.Marquee
                .Enabled = True
            End With

            'scarica il file selezionato
            lbStato.Text = "scarico il documento..."

            Arg.Operazione = Globale.TipoOperazioneLiquido.VISUALIZZA

            BackgroundWorker1.RunWorkerAsync(Arg)

        Catch ex As Exception
            Globale.Log.Errore(ex)
        End Try

    End Sub

    Private Sub btnSalvaFile_Click(sender As System.Object, e As System.EventArgs) Handles btnSalvaFile.Click
        Try
            If ListBoxDocumenti.SelectedIndex < 0 Then
                MsgBox("Selezionate prima il documento da salvare", MsgBoxStyle.Exclamation, Utx.Globale.TitoloApp)
                Exit Sub
            End If

            Dim Arg As New SertelEventArgs

            If ListBoxDocumenti.Tag = Globale.TipoOperazioneLiquido.LISTALIQUIDO Then

                If ListBoxDocumenti.SelectedItem.IdFile.Length = 0 Then Exit Sub

                Arg.DocInfo = ListBoxDocumenti.SelectedItem
                Arg.FullPathFileDest = FileDestinazione(mCartellaLocaleSinistro)
            Else
                Arg.DocInfo = ListBoxDocumenti.SelectedItem
                Arg.FullPathFileDest = FileDestinazione(mCartellaLocaleSinistro)
            End If

            If Not Directory.Exists(mCartellaLocaleSinistro) Then
                Directory.CreateDirectory(mCartellaLocaleSinistro)
            End If

            'controlla se il file già esiste
            If File.Exists(Arg.FullPathFileDest) Then
                MsgBox("Nella cartella esiste già un file con lo stesso nome.", MsgBoxStyle.Exclamation, Utx.Globale.TitoloApp)
                Exit Sub
            End If

            With pbInvio
                .Style = ProgressBarStyle.Marquee
                .Enabled = True
            End With

            'scarica il file selezionato
            lbStato.Text = "scarico il documento..."

            Arg.Operazione = Globale.TipoOperazioneLiquido.SALVA

            BackgroundWorker1.RunWorkerAsync(Arg)

        Catch ex As Exception
            Globale.Log.Errore(ex)
        End Try

    End Sub

    Private Sub ControlloCartellaSinistro(CartellaSinistro As String)
        If Not Directory.Exists(CartellaSinistro) Then Directory.CreateDirectory(CartellaSinistro)
    End Sub

    Private Sub lbStato_TextChanged(sender As Object, e As System.EventArgs) Handles lbStato.TextChanged
        lbStato.Refresh()
    End Sub

    Private Sub btnLog_Click(sender As System.Object, e As System.EventArgs) Handles btnLog.Click
        Globale.Log.ApriLog()
    End Sub

    Private Function FileDestinazione(CartellaDestinazione As String) As String
        Try
            Dim d As Utx.ImportaSinistriOMW.DocumentoInfo = ListBoxDocumenti.SelectedItem

            If d.Nome.ToUpper.EndsWith(d.FileExt.ToUpper) Then
                Return Path.Combine(CartellaDestinazione, Documenti.AggiungiProtocollo(d.Nome, d.DataCaricamento))
            Else
                Return Path.Combine(CartellaDestinazione, Documenti.AggiungiProtocollo(d.Nome + d.FileExt, d.DataCaricamento))
            End If

        Catch ex As Exception
            Return "Errore"
        End Try
    End Function
End Class

