Imports System.IO
Imports System.Windows.Forms
Imports System.Drawing

Public Class FormDownloadLiquido

    Public Log As New Utx.ApplicationLog("UploadSertel.log")
    Friend FlagWip As Boolean
    Private SinistroCorrente As Sinistri

    Sub New()

        ' Chiamata richiesta dalla finestra di progettazione.
        InitializeComponent()

        ' Aggiungere le eventuali istruzioni di inizializzazione dopo la chiamata a InitializeComponent().
        'impo finestra
        Me.FormBorderStyle = Windows.Forms.FormBorderStyle.Sizable
        Me.StartPosition = FormStartPosition.CenterScreen
        Me.Size = New Size(600, 400)
        Me.MinimumSize = New Size(Me.Width, Me.Height)
        Me.Icon = Risorse.Immagini.Icon("view")
    End Sub

#Region "proprietà"
