    Public Function RamoGestioneToComparto(RamoGestione As Integer) As Integer
        Select Case RamoGestione
            Case 0 : Return 0
            Case 1, 2 : Return 1
            Case 3, 4, 5 : Return 2
            Case 6, 7, 8, 9, 21, 22, 23 : Return 3
            Case 11, 12, 13, 14, 16, 17 : Return 4
            Case 18, 19, 20 : Return 5
            Case 10 : Return 6
        End Select
    End Function
End Module
