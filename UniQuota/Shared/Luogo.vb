    Public Shared Function GetProvinciaByName(ByVal denominazione As String) As ProvinciaEnum
        For Each provincia As Provincia In Province.Values
            If denominazione.ToUpper = provincia.Nome.ToUpper Then
                Return provincia.IdProvincia
            End If
        Next
        Return ProvinciaEnum.SiglaXX
    End Function

    Public Shared Function GetProvinciaBySigla(ByVal sigla As String) As ProvinciaEnum
        If Not String.IsNullOrEmpty(sigla) Then
            For Each provincia As Provincia In Province.Values
                If sigla.ToUpper = provincia.Sigla.ToUpper Then
                    Return provincia.IdProvincia
                End If
            Next
        End If
        Return ProvinciaEnum.SiglaXX
    End Function

    Public Shared Function GetRegioneByName(ByVal denominazione As String) As RegioneEnum
        For Each regione As Regione In Regioni.Values
            If denominazione.ToUpper = regione.Nome.ToUpper Then
                Return regione.IdRegione
            End If
        Next
        Return RegioneEnum.REGIONE
    End Function

    Public Shared Function GetComuneByCodiceIstat(ByVal CodiceIstat As Integer) As Comune
        For Each comune As Comune In Comuni
            If comune.CodiceIstat = CodiceIstat Then
                Return comune
            End If
        Next
        Return GetComuneNotSelected()
    End Function

    Public Shared Function GetComuneNotSelected() As Comune
        Return Comuni(0)
    End Function
End Class

Public Class Regione
    Public IdRegione As RegioneEnum
    Public Sigla As String
    Public Nome As String

    Public Sub New(ByVal IdRegione As RegioneEnum, ByVal Sigla As String, ByVal Nome As String)
        Me.IdRegione = IdRegione
        Me.Sigla = Sigla
        Me.Nome = Nome
    End Sub

    Public Overrides Function ToString() As String
        Return Nome
    End Function
End Class


Public Class Provincia
    Public IdProvincia As ProvinciaEnum
    Public Regione As Regione
    Public Sigla As String
    Public Nome As String

    Public Sub New(ByVal IdProvincia As ProvinciaEnum, ByVal IdRegione As RegioneEnum, ByVal Sigla As String, ByVal Nome As String)
        Me.IdProvincia = IdProvincia
        Me.Regione = Luogo.Regioni(IdRegione)
        Me.Sigla = Sigla
        Me.Nome = Nome
    End Sub

    Public Overrides Function Equals(obj As Object) As Boolean
        If Not TypeOf obj Is Provincia Then Return False

        Return IdProvincia = CType(obj, Provincia).IdProvincia
    End Function

    Public Overrides Function ToString() As String
        Return Nome
    End Function
End Class


Public Class Comune
    Public CodiceIstat As Integer
    Public Nome As String
    Public CodiceCatastale As String
    Public Regione As Regione
    Public Provincia As Provincia
    Public Cap As String
    Public Cab As String '= "82930"

    Public Sub New(ByVal CodiceCatastale As String, ByVal CodiceIstat As Integer, ByVal IdProvincia As ProvinciaEnum, ByVal Nome As String, ByVal Cap As String)
        Me.CodiceIstat = CodiceIstat
        Me.CodiceCatastale = CodiceCatastale
        Me.Provincia = Luogo.Province(IdProvincia)
        Me.Regione = Provincia.Regione
        Me.Nome = Nome
        Me.Cap = Cap
    End Sub

    Public Overrides Function ToString() As String
        Return Nome
    End Function
End Class



