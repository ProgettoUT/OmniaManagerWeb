    <estrazione>
	<sql profili="tutti"><![CDATA[
	SELECT 
	    SI.EsercizioSinistro          AS [Esercizio sinistro], 
	    format(SI.RamoSinistro,'000') AS [Ramo sinistro codice],
	    TRS.DesRamoSinistro           AS [Ramo sinistro descrizione], 
	    format(SI.RamoPolizza,'000')  AS [Ramo Polizza codice],
	    TR1.Ramo                      AS [Ramo Polizza descrizione], 
	    SI.Polizza                    AS [polizza Sinistro], 
	    SI.CodiceSubAgenteSima        AS [Codice sub agente sinistro], 
	    SI.Datasinistro               AS [Data accadimento sinistro], 
	    SI.DataDenuncia               AS [Data denuncia], 
	    SI.tipocid                    AS [Tipologia Cid codice],
	    (Switch([tipocid]="1", "Gestione CID - Attiva"
	          , [tipocid]="2", "Gestione CID - Parziale"
	          , [tipocid]="4", "Gestione CID - Passiva"
	          , [tipocid]="5", "Gestione CARD Gestionaria - Attivi"
	          , [tipocid]="6", "Gestione CARD Mista - 50%"
	          , [tipocid]="7", "Gestione CARD Debitrice - Passivi a forfait"
	          , [tipocid]="8", "RCA attiva assistenza ai clienti")) 
	                                  AS [Tipologia Cid descrizione], 
	    SI.Tipochiusura               AS [Tipologia chiusura codice],
	    (Switch([Tipochiusura]="..", "aperto"
	          , [Tipochiusura]="LT", "liquidato"
	          , [Tipochiusura]="SS", "senza seguito")) 
	                                  AS [Tipologia chiusura descrizione], 
	    SI.TipoSinistro               AS [Tipologia sinistro codice],
	    TSI.DescTipoSin               AS [Tipologia sinistro descrizione], 
	    SI.Pagatodel                  AS [Pagato del], 
	    SI.Pagatoal                   AS [Pagato al], 
	    SI.RecuperoDel                AS [Recupero del], 
	    SI.RecuperoAl                 AS [Recupero al], 
	    SI.CodiceProdotto             AS [Prodotto sinistro], 
	    C.Cognome                     AS [Cognome assicurato], 
	    C.Nome                        AS [Nome assicurato],
	    SI.DataUltPagam               AS [Ultimo Pagamento],
            SI.Riserva                    AS [Riserva], 
            SI.DataApertura               AS [Data Apertura],
            SI.RamoGestione               AS [Ramo gestione codice],
            TRG.DescRamoGest              AS [Ramo gestione descrizione],
            SI.IdStatoCliente             AS [Stato cliente codice],
            TSC.StatoCliente              AS [Stato cliente descrizione],
            SI.IdGestione                 AS [Gestione],
	    SI.Ispettorato                AS [Ispettorato codice],
	    TSI.DescTipoSin               AS [Ispettorato descrizione]
	FROM ((((((([Sinistri]  AS SI 
	LEFT JOIN [CLIENTI] AS C 
  	  ON (C.CODICEFISCALE = SI.CODICEFISCCONTRPOL))
	LEFT JOIN [TipoRamiSinistro] AS TRS 
  	  ON (TRS.RamoSinistro = SI.RamoSinistro))
	LEFT JOIN [TipoRami] AS TR1 
	  ON (TR1.CodiceRamo = SI.RamoPolizza)) 
	LEFT JOIN [TipoSinistro] AS TSI 
 	  ON (TSI.RamoSinistro = SI.RamoSinistro AND TSI.TipoSinistro = SI.TipoSinistro)) 
	LEFT JOIN [RamoGest] AS TRG 
 	  ON (TRG.RamoGestione = SI.RamoGestione )) 
	LEFT JOIN [TipoStatiCliente] AS TSC 
 	  ON (TSC.IDStatoCliente = SI.IdStatoCliente)) 
	LEFT JOIN [Ispettorato] AS TIS 
 	  ON (TIS.Ispettorato = SI.Ispettorato)) 
			]]></sql>
	
